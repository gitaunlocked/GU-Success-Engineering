# Razorpay API Keys (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Razorpay Webhook Secret (Dashboard → Settings → Webhooks)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Backend API URL (point to your Vercel backend)
API_BASE_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# MongoDB — stores Success Engineering registrations
# Get a free connection string from MongoDB Atlas (cloud.mongodb.com).
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=gitaunlocked
MONGODB_COLLECTION=seRegistrations
MONGODB_ASSESSMENT_COLLECTION=seAssessmentResponses

# ---------------------------------------------------------------------------
# Email (Success Engineering registration confirmation + admin notification)
# Optional: if left unset, registrations are still stored, just no emails sent.
# Use an app-specific SMTP credential (e.g. Gmail App Password, Resend, SES SMTP).
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_app_password
MAIL_FROM="Gita Unlocked <hello@gitaunlocked.com>"
ADMIN_NOTIFY_EMAIL=admin@gitaunlocked.com
